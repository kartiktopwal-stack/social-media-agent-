# ════════════════════════════════════════════════════════════════════════════
#  AI CONTENT EMPIRE — Environment Configuration
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════════════

# ─── System ──────────────────────────────────────────────────────────────────
ENV=development        # development | production
LOG_LEVEL=INFO
TZ=UTC

# ─── Database (Supabase) ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
DATABASE_URL=postgresql+psycopg://empire:empire_dev_password@postgres:5432/content_empire

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── AI / LLM (Google Gemini - Free tier: 1500 req/day) ─────────────────────────
GEMINI_API_KEY=your_gemini_api_key
AI_MODEL=gemini-1.5-flash
AI_MAX_TOKENS=2000

# ─── AI / LLM (NVIDIA Nemotron - Free tier via NVIDIA API) ─────────────────────
# Used specifically for virality scoring. Get key from https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=your_nvidia_api_key
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ─── Voice Generation (edge-tts - Free Microsoft Edge TTS) ─────────────────────
# No API key needed for edge-tts
TTS_VOICE=en-US-AriaNeural

# ─── Trend Sources ───────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ContentEmpire/1.0 (by /u/your_username)

# ─── Video / Visuals ─────────────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key
RUNWAY_API_KEY=your_runway_api_key
STABILITY_API_KEY=your_stability_api_key

# ─── Publishing — YouTube ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret

# ─── Publishing — Meta (Instagram) ───────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ─── Publishing — TikTok ─────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ─── Publishing — X/Twitter ──────────────────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# ─── Storage ─────────────────────────────────────────────────────────────────
OBJECT_STORAGE_BACKEND=local   # s3 | local
OBJECT_STORAGE_PREFIX=content-empire
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
LOCAL_OBJECT_STORAGE_ROOT=data/object_store
S3_BUCKET=content-empire-videos
S3_REGION=auto
CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key

# ─── Monitoring / Alerts ─────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Schedule (cron-style) ────────────────────────────────────────────────────
DAILY_RUN_HOUR=5          # 5 AM UTC
PUBLISH_HOUR=14           # 2 PM UTC (optimal for most platforms)
MAX_VIDEOS_PER_NICHE=3    # videos to produce per niche per day
WORKSPACE_ROOT=data/workspaces
PUBLISH_PARALLELISM=4
DASHBOARD_REQUIRE_AUTH=true
DASHBOARD_API_KEY=change_me_for_production
JOB_CLAIM_TIMEOUT_SECONDS=1800
MAX_RETRY_ATTEMPTS=4
RETRY_BACKOFF_SECONDS=2
